  "questions": [
    {
      "id": "op01_floor_div_mod",
      "type": "output",
      "title": "整除与取模",
      "instruction": "给定 `n = 100`，计算并打印：\n1. n 除以 7 的商（整除）\n2. n 除以 7 的余数",
      "initialCode": "n = 100\n# 在下方编写代码\n",
      "testConfig": {
        "expected": "14\n2",
        "timeout_ms": 5000
      },
      "hints": [
        { "text": "// 整除，% 取余", "visible": true }
      ]
    },
    {
      "id": "op02_power_parentheses",
      "type": "output",
      "title": "幂运算与括号",
      "instruction": "计算 `2 的 3 次方再 + 1`，然后乘以 2。\n\n即：(2³ + 1) × 2",
      "initialCode": "# 在下方编写代码\n",
      "testConfig": {
        "expected": "18",
        "timeout_ms": 5000
      },
      "hints": [
        { "text": "(2**3 + 1) * 2", "visible": true }
      ]
    },
    {
      "id": "op03_divmod",
      "type": "output",
      "title": "divmod 函数",
      "instruction": "使用 divmod() 函数计算 100 除以 7 的商和余数，打印结果。\n\ndivmod(a, b) 返回 (商, 余数)",
      "initialCode": "# 在下方编写代码\n",
      "testConfig": {
        "expected": "(14, 2)",
        "timeout_ms": 5000
      },
      "hints": [
        { "text": "divmod(100, 7)", "visible": true }
      ]
    },
