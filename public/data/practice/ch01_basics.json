    {
      "id": "q15_bmi",
      "type": "output",
      "title": "BMI计算",
      "instruction": "计算 BMI 指数。已知体重 `weight = 70` kg，身高 `height = 1.75` m。\n\n公式：BMI = 体重(kg) / 身高(m)²\n\n打印 BMI 值，保留1位小数。",
      "initialCode": "weight = 70\nheight = 1.75\n# 在下方编写代码\n",
      "testConfig": {
        "expected": "22.9",
        "timeout_ms": 5000
      },
      "hints": [
